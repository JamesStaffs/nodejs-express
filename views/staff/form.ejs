<%- include('../partials/header', { title: person.id ? 'Edit Staff' : 'New Staff' }) %>
<h1><%= person.id ? 'Edit Staff' : 'New Staff' %></h1>
<form action="<%= action %>" method="POST">
  <label>Staff ID:<br>
    <input type="text" name="staff_id" value="<%= person.staff_id || '' %>" required>
  </label><br>
  <label>Full Name:<br>
    <input type="text" name="full_name" value="<%= person.full_name || '' %>" required>
  </label><br>
  <button type="submit">Save</button>
</form>
<%- include('../partials/footer') %>